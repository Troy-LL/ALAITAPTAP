# SafeRoute environment variables
# Copy to .env and fill in your actual values
# NEVER commit .env to git!

# Database (use SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./saferoute.db
# For Railway PostgreSQL: DATABASE_URL=postgresql://user:pass@host:port/saferoute

# OpenRouteService - Free tier: 2000 req/day
# Sign up at: https://openrouteservice.org/dev/#/signup
OPENROUTESERVICE_API_KEY=your_openrouteservice_api_key_here

# Twilio SMS - Free trial: ~$15 credit (~100 SMS)
# Sign up at: https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Optional: override path to Overpass/OSM GeoJSON (street lamps, surveillance, police)
# Default is data/export.geojson next to the backend app.
# OSM_GEOJSON_PATH=C:\path\to\export.geojson

# Safety scorer: merge export.geojson into safe_spots.csv (see data/merge_export_geojson_into_safe_spots.py),
# then set SAFETY_IGNORE_CRIME=1 and SAFETY_USE_OSM_FILE=0 to score routes from public infrastructure only
# (no crime_incidents), without double-counting OSM from the file + DB.
# SAFETY_IGNORE_CRIME=1
# SAFETY_USE_OSM_FILE=0

# App Settings
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,https://saferoute-asean.vercel.app
